# FunASR 转录服务器环境变量配置示例
# 复制此文件为 .env 并根据需要修改配置
#
# 配置优先级 (后者覆盖前者):
#   defaults < config.json < FUNASR_PROFILE < FUNASR_* env (本文件)
#
# 切设备 / 切引擎的操作手册见 CLAUDE.md "Config 体系 > 切换设备/切引擎操作手册"
# (4 种设备×引擎组合的实际命令 + 改哪里决策树 + 启动后怎么验证)


# ==================== FUNASR_PROFILE 套餐 (推荐, 一句话切平台) ====================
# 设这一个 env, 自动填好 port / engine / pool / encoder / log 5 个字段, 不再手工拼.
# 详见 CLAUDE.md "Config 体系" 章节.
#
# 可选 profile:
#   mac_prod  : port=8767, engine=qwen3, pool=3, encoder=coreml_ane_full, INFO
#   mac_dev   : port=8867, engine=qwen3, pool=2, encoder=coreml_ane_full, DEBUG
#   cuda_prod : engine=qwen3, pool=2, encoder=cuda, INFO
#   cuda_dev  : port=8867, engine=qwen3, pool=2, encoder=cuda, DEBUG
#
# 启动日志会显示 "FUNASR_PROFILE=X applied. 覆盖字段(N): ..." 确认哪些字段被 profile 覆盖.
# env 仍可覆盖 profile (escape hatch), 未知 profile name → warn + ignore 不挂.
# FUNASR_PROFILE=mac_dev


# ==================== 服务器配置 ====================
# WebSocket 服务器监听地址
FUNASR_SERVER_HOST=0.0.0.0

# WebSocket 服务器监听端口
FUNASR_SERVER_PORT=8767

# 最大连接数 (可选，覆盖 config.json)
# FUNASR_SERVER_MAX_CONNECTIONS=100

# 最大文件大小限制 MB (可选，覆盖 config.json)
# FUNASR_SERVER_MAX_FILE_SIZE_MB=5000


# ==================== 敏感信息（必需）====================
# 企业微信 Webhook URL
# 格式: https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your-webhook-key-here
# 如果启用通知功能 (FUNASR_NOTIFICATION_ENABLED=true)，此项必填
FUNASR_WEBHOOK_URL=

# JWT 认证密钥
# 如果启用认证功能 (FUNASR_AUTH_ENABLED=true)，生产环境务必修改此密钥！
FUNASR_AUTH_SECRET_KEY=your-secret-key-change-this-in-production


# ==================== 功能开关 ====================
# 是否启用 JWT 认证 (开发环境: false, 生产环境: true)
FUNASR_AUTH_ENABLED=false

# 是否启用企业微信通知
FUNASR_NOTIFICATION_ENABLED=true


# ==================== 日志配置 ====================
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
# 开发环境建议 DEBUG，生产环境建议 INFO 或 WARNING
FUNASR_LOG_LEVEL=INFO


# ==================== 目录配置 ====================
# FunASR 模型文件存储目录
FUNASR_MODEL_DIR=./models

# 上传文件临时存储目录
FUNASR_UPLOAD_DIR=./uploads

# 临时文件目录
FUNASR_TEMP_DIR=./temp

# 日志文件存储目录
FUNASR_LOG_DIR=./logs

# 数据库文件存储目录
FUNASR_DATA_DIR=./data


# ==================== FunASR 模型配置 ====================
# 计算设备: auto (自动选择), cpu, cuda, mps (Mac GPU)
# auto 模式会根据 FUNASR_DEVICE_PRIORITY 自动选择可用设备
FUNASR_DEVICE=auto

# 设备优先级 (逗号分隔，无空格)
# 示例: mps,cpu (Mac 优先用 GPU) 或 cuda,cpu (Linux/Windows 优先用 NVIDIA GPU)
FUNASR_DEVICE_PRIORITY=mps,cpu

# FunASR 使用的 CPU 线程数 (可选，覆盖 config.json)
# 建议设置为物理核心数
# FUNASR_NCPU=16

# FunASR 批处理大小（秒）(可选，覆盖 config.json)
# 较大的值可以提高吞吐量但会增加内存占用
# FUNASR_BATCH_SIZE_S=500


# ==================== 转录任务配置 ====================
# 最大并发转录任务数 (可选，覆盖 config.json)
# 建议设置为 CPU 核心数的一半，避免过载
# FUNASR_MAX_CONCURRENT_TASKS=2

# 单个任务超时时间（分钟）(可选，覆盖 config.json)
# FUNASR_TASK_TIMEOUT_MINUTES=30

# 转录速度比率（RTF 的倒数）(可选，覆盖 config.json)
# 说明：
# - RTF (Real-Time Factor) = 转录耗时 / 音频时长
# - transcription_speed_ratio = 1 / RTF
# - 例如：RTF=0.1 时，transcription_speed_ratio=10（转录速度是实时播放的10倍）
# - 不同设备性能差异大，建议根据实际测试结果设置
# 推荐配置：
# - Apple M1/M2 (MPS): 10-15
# - Intel/AMD CPU: 5-10
# - NVIDIA GPU: 15-30
# - 默认：10
# FUNASR_TRANSCRIPTION_SPEED_RATIO=10

# 默认 ASR 引擎(全局唯一引擎模式 — 服务器启动后只跑这一个)
# 当 upload_request 不显式指定 engine 字段时, 走这个引擎
# 当 upload_request.engine 与之不匹配时, 立即 reject(不入队), 错误返回 client
# 支持值:
#   - funasr      基于 FunASR 的转录 + cam++ 说话人识别(生产默认)
#   - qwen3       Qwen3-ASR 1.7B GGUF + sherpa-onnx speaker diarization
# FUNASR_DEFAULT_ENGINE=funasr

# 跨引擎缓存共享(默认 true)
# true:  请求 engine=qwen3 时, 若有 funasr 的历史缓存也能命中(避免切换引擎后重转)
#        SRT 命中时从 TranscriptionResult.segments 重建, 字节级与 FunASR 一致
# false: strict 模式, 仅按 (file_hash, engine) 精确匹配, 切换引擎必须重转
# FUNASR_CACHE_CROSS_ENGINE=true

# Qwen3 引擎专用 worker pool 大小(独立于 max_concurrent_tasks)
# - FunASR pool 用 max_concurrent_tasks(物理最优 2, MPS 单 context 串行)
# - Qwen3  pool 用 qwen3_pool_size(PoC v5 sweet spot 3, GPU 97% 满载)
# - N=2  快速验证, 模型加载减半
# - N=3  生产推荐, throughput 2.12 task/min (5min 双人音频)
# - N>=4 GPU 100% 饱和, 纯排队不会更快
# FUNASR_QWEN3_POOL_SIZE=3


# ==================== Qwen3-Diarize 引擎配置(仅 default_engine=qwen3 生效) ====================
# 模型路径(默认指向 scripts/download_qwen3_models.sh 落地的位置)
# FUNASR_QWEN3_ASR_MODEL_DIR=./models/qwen3_diarize/Qwen3-ASR-1.7B
# FUNASR_QWEN3_SEGMENTATION_MODEL=./models/qwen3_diarize/sherpa/pyannote-segmentation-3.0/model.onnx
# FUNASR_QWEN3_EMBEDDING_MODEL=./models/qwen3_diarize/sherpa/nemo-titanet-small/embedding.onnx

# Diarize preset (PoC 报告 preset=auto 普适最优:
# fp32 segmentation + NeMo TitaNet small + cpu + 4 threads + 自适应聚类)
# num_speakers: 已知人数填整数(如 2 锁簇), 未知填 auto / 空 / none
# FUNASR_QWEN3_NUM_SPEAKERS=auto
# FUNASR_QWEN3_CLUSTER_THRESHOLD=0.9
# num_threads: 默认 "auto" 走 detect_runtime().recommend_num_threads()
#   - MacRuntime  → 4 (PoC: t=4 比 t=8 wall -11.5%, M1 Max + pool=2)
#   - CudaRuntime → 2/4 按 vCPU (≤4=2, ≥5=4)
# 公式 pool_size × num_threads ≤ 物理 cores - 2 (留给系统)
# 详见 spikes/qwen3_mac_hw_accel/SUMMARY.md
# FUNASR_QWEN3_NUM_THREADS=auto

# provider (sherpa embedding extractor 用): 默认 "auto" → "cpu" (所有 runtime 都走 cpu)
# FUNASR_QWEN3_PROVIDER=auto

# ASR encoder ONNX provider — Qwen3 ASR encoder 跑在哪个 EP
# auto (默认): macOS → COREML_ANE_FE (frontend ANE, backend CPU), 其他 → CPU
# cpu: 强制 CPU (生产 ANE 出问题一键回退)
# coreml_ane_fe: 强制 frontend ANE + backend ONNX CPU (Phase 2)
# coreml_ane_full: frontend ANE + backend mlpackage ANE (Phase 3, 生产稳定 cos=0.9891)
# cuda: NVIDIA CUDA (Linux CUDA runtime 推荐)
# tensorrt: NVIDIA TensorRT (实验)
# 详见 spikes/qwen3_mac_hw_accel/coreml_asr_encoder.md
# FUNASR_QWEN3_ASR_ENCODER_PROVIDER=auto

# Qwen3 后端 mlpackage compute_units (仅 ASR_ENCODER_PROVIDER=coreml_ane_full 生效)
# CPU_AND_NE (默认): frontend ANE + backend mlpackage ANE
#                    ⚠️ N≥2 并发可能跟 frontend ANE 4 路冲突触发 llama.cpp ggml_abort
# CPU_AND_GPU: frontend 独占 ANE + backend Metal GPU (production pool>=2 推荐)
# ALL: 三路全开 (macOS 26 Beta 有 issue, 仅 dev 实验)
# FUNASR_QWEN3_BACKEND_MLPACKAGE_UNITS=CPU_AND_NE

# Qwen3 encoder timing 调试开关 — 打印 mel/frontend/backend 每段耗时
# 生产默认 false, 排查性能问题时临时打开看每段耗时
# FUNASR_QWEN3_ENCODER_TIMING=false

# Diarize backend (cuda runtime 上替代 sherpa, 详见 docs/开发/gpu加速/2026-05-22-ORT-CUDA-diarize-backend.md)
# auto (默认 — runtime 自动选): Mac/Cpu → sherpa, Cuda → ort_cuda
# sherpa: 强制 sherpa C++ FastClustering (跨平台稳定)
# ort_cuda: 强制 onnxruntime CUDA + scipy 复刻 (Linux CUDA 上 30min RTF 0.047)
# FUNASR_QWEN3_DIARIZE_BACKEND=auto

# Runtime override (跨平台 escape hatch, 用于 dev/CI 一键回退)
# auto (默认): platform 自动探测 (darwin → mac_ane, linux+CUDA → cuda, 其他 → cpu)
# cpu / mac_ane / cuda: 强制走指定 runtime, 不做 platform 探测
# FUNASR_RUNTIME=auto

# ASR 参数
# FUNASR_QWEN3_LANGUAGE=Chinese
# FUNASR_QWEN3_TEMPERATURE=0.4

# PR2 short-segment guard 后处理 (默认全开, PoC v12 验证对所有 baseline 都正向)
# - SHORT_GUARD_ENABLED: 总开关, false 禁用全部 guard
# - SHORT_DROP_SEC: < 此值的微短段并入相邻邻居 (建议 0.3-1.5, 0.3 更激进合并)
# - SHORT_ABA_MAX_MID_SEC: A-B-A 抖动平滑中, B 段最大时长 (>此值不平滑)
# - SHORT_MERGE_SAME: ABA 后是否合并连续同 speaker 段
# FUNASR_QWEN3_SHORT_GUARD_ENABLED=true
# FUNASR_QWEN3_SHORT_DROP_SEC=1.5
# FUNASR_QWEN3_SHORT_ABA_MAX_MID_SEC=1.5
# FUNASR_QWEN3_SHORT_MERGE_SAME=true

# PR3 cluster centroid merge (多人场景关键修复, 默认全开)
# 加载 audio + sherpa embedding extractor 算 centroid, 把过聚的 cluster 合并.
# - CLUSTER_MERGE_ENABLED: 总开关, false 禁用全部合并
# - MIN_MAIN_SHARE: 占比 >= 此值才算主 cluster (其余视为 minor, 0.03=3%)
# - RELABEL_THRESHOLD: minor -> 最近 main 的 cosine 阈值 (低于此保留独立)
# - MAIN_THRESHOLD: main 间 high-conf 合并阈值 (适合明显同一人)
# - DOMINANT_SHARE: 合并后存在 share >= 此值的 cluster 触发 dominant 模式
# - DOMINANT_THRESHOLD: dominant 模式下其他 main 与 dom 的合并阈值 (更宽容)
# FUNASR_QWEN3_CLUSTER_MERGE_ENABLED=true
# FUNASR_QWEN3_CLUSTER_MERGE_MIN_MAIN_SHARE=0.03
# FUNASR_QWEN3_CLUSTER_MERGE_RELABEL_THRESHOLD=0.55
# FUNASR_QWEN3_CLUSTER_MERGE_MAIN_THRESHOLD=0.78
# FUNASR_QWEN3_CLUSTER_MERGE_DOMINANT_SHARE=0.6
# FUNASR_QWEN3_CLUSTER_MERGE_DOMINANT_THRESHOLD=0.6

# silence-aware 段切点对齐 (spike 405abf6, 默认开)
# ffmpeg silencedetect + snap-to-silence 把段切点吸附到最近静音中点.
# 60s podcast align_ratio +19pp, 60min long +33pp, RTF 影响 <1%.
# 详见 spikes/qwen3_silence_align/SUMMARY.md
# - SILENCE_ALIGN_ENABLED: 总开关, false 禁用全部 snap (回退原 chunk 边界时间戳)
# - SILENCE_ALIGN_TOLERANCE_SEC: 吸附容忍窗口 (秒), 距 silence mid > 此值不动
# - SILENCE_ALIGN_MIN_SEGMENT_DUR_SEC: snap 后段时长 < 此值则回退, 保护段不退化
# - SILENCE_VAD_NOISE_DB: ffmpeg silencedetect 噪声门限 (越敏感 |dB| 越小)
# - SILENCE_VAD_MIN_SILENCE_SEC: 最短 silence 时长门限 (秒)
# FUNASR_QWEN3_SILENCE_ALIGN_ENABLED=true
# FUNASR_QWEN3_SILENCE_ALIGN_TOLERANCE_SEC=2.0
# FUNASR_QWEN3_SILENCE_ALIGN_MIN_SEGMENT_DUR_SEC=0.1
# FUNASR_QWEN3_SILENCE_VAD_NOISE_DB=-25dB
# FUNASR_QWEN3_SILENCE_VAD_MIN_SILENCE_SEC=0.20

# 词级时间戳 (word_align, MMS-300M CTC-FA; 字段默认关, cuda_prod/cuda_dev profile 默认开)
# 增量挂 segment.words (绝对秒), 不替换段边界, JSON-only. 多语种.
# 模型预下: bash scripts/download_qwen3_models.sh --word-align (~1.2GB)
# RTF 代价: Mac CPU +17% / RTX 3060 CUDA +1% (见 spikes/qwen3_word_timestamp/SUMMARY.md)
# ⚠️ CUDA 机器装 ctc-forced-aligner 会覆盖 onnxruntime-gpu, 需修复 (见 docs/部署.md 五节 + requirements.txt)
# - WORD_ALIGN_ENABLED: 总开关
# - WORD_ALIGN_LANGUAGE: 兜底语言 ISO 码 (chi/eng/jpn/kor...), per-request language 字段优先; 中英混排用 chi
# - WORD_ALIGN_MODEL_PATH: MMS ONNX 本地路径
# - WORD_ALIGN_PROVIDER: auto (Mac/Cpu→CPU EP, Cuda→CUDA EP) / cpu / cuda
# - WORD_ALIGN_BATCH_SIZE: generate_emissions ONNX 推理 batch
# FUNASR_QWEN3_WORD_ALIGN_ENABLED=false
# FUNASR_QWEN3_WORD_ALIGN_LANGUAGE=chi
# FUNASR_QWEN3_WORD_ALIGN_MODEL_PATH=./models/qwen3_diarize/ctc_forced_aligner/model.onnx
# FUNASR_QWEN3_WORD_ALIGN_PROVIDER=auto
# FUNASR_QWEN3_WORD_ALIGN_BATCH_SIZE=16


# ==================== 平台特定优化 ====================
# OpenMP 线程数（控制底层并行计算库的线程池大小）
# 说明：
# - 影响 PyTorch、NumPy 等科学计算库的 CPU 并行运算
# - 建议值：CPU 核心数的 1/2 到 1/1（并发场景建议较小值）
# - 过大会导致线程竞争，反而降低性能
# - 过小会浪费 CPU 资源
# 推荐配置：
# - 单任务场景：设置为 CPU 核心数（如 8 核设为 8）
# - 多任务并发：设置为核心数的一半（如 8 核设为 4）
# - 默认：4（适合大多数场景）
OMP_NUM_THREADS=4

# PyTorch MPS 内存管理配置（仅 macOS Apple Silicon GPU 加速时生效）
# 说明：
# - MPS = Metal Performance Shaders（Apple GPU 加速框架）
# - 控制 GPU 内存缓存策略的"高水位线"比例
# - 0.0 = 禁用缓存，每次都释放 GPU 内存
# - 0.3 = 保留 30% 内存作为缓存，提升性能但可能 OOM
# 优势：
# - 0.0 避免长时间运行时的内存碎片化问题
# - 0.0 支持多任务并发时的内存共享
# - 0.0 提高系统稳定性，避免 OOM 崩溃
# 代价：
# - 0.0 会略微降低性能（频繁分配/释放内存）
# 推荐配置：
# - 服务器长时间运行：0.0（稳定性优先）
# - GPU 内存充足且单任务：0.3-0.5（性能优先）
# - 默认：0.0（本项目默认值，已在代码中自动设置）
PYTORCH_MPS_HIGH_WATERMARK_RATIO=0.0


# ==================== Docker 配置 ====================
# Docker Compose 项目名称 (仅在 Docker 环境中使用)
# COMPOSE_PROJECT_NAME=funasr
